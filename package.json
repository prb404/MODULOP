{
  "name": "modulop",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite --host 127.0.0.1 --port 8080",
    "dev": "vite --host 127.0.0.1 --port 8080",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 8080",
    "test": "vitest run",
    "check": "npm run test && npm run build",
    "qa:browser": "node scripts/browser-qa.mjs",
    "qa:realtime": "node scripts/realtime-qa.mjs",
    "smoke:ui": "node scripts/smoke-ui.mjs",
    "release:patch": "npm version patch --no-git-tag-version && npm run version:stamp",
    "release:minor": "npm version minor --no-git-tag-version && npm run version:stamp",
    "release:major": "npm version major --no-git-tag-version && npm run version:stamp",
    "version:stamp": "node scripts/stamp-version.mjs"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@floating-ui/dom": "^1.7.6",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@tabler/icons": "^3.44.0",
    "@toast-ui/editor": "^3.2.2",
    "d3": "^7.9.0",
    "dexie": "^4.4.3",
    "dompurify": "^3.4.10",
    "echarts": "^6.0.0",
    "emoji-picker-element": "^1.29.1",
    "emoji-picker-element-data": "^1.8.0",
    "gridstack": "^12.6.0",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "lucide": "^1.18.0",
    "marked": "^18.0.5",
    "material-symbols": "^0.45.1",
    "three": "^0.184.0",
    "trystero": "^0.25.2",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.0.0",
    "playwright-core": "^1.61.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "dompurify": "$dompurify",
    "esbuild": "0.28.1"
  }
}
